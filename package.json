{
  "name": "zombie-survivor",
  "private": true,
  "version": "0.0.0",
  "description": "A browser-based 2D zombie survivor roguelite built with TypeScript, Vite, Canvas 2D, and a custom ECS.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hhzz-svg/zombie-survivor.git"
  },
  "homepage": "https://github.com/hhzz-svg/zombie-survivor#readme",
  "bugs": {
    "url": "https://github.com/hhzz-svg/zombie-survivor/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "pngjs": "^7.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
